<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Playbook Master — ICBID Pós-Graduação T2</title>
<style>
:root {
  --gold: #c9a84c;
  --gold-light: #e8c96a;
  --gold-dim: #8a6e2a;
  --bg: #0d0d0d;
  --surface: #161616;
  --surface2: #1e1e1e;
  --surface3: #252525;
  --border: #2a2a2a;
  --text: #e8e4dc;
  --text-dim: #8a8580;
  --text-muted: #555;
  --red: #c0392b;
  --green: #27ae60;
  --blue: #2980b9;
  --amber: #e67e22;
  --purple: #8e44ad;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Georgia',serif;font-size:14px;line-height:1.6;}
a{color:var(--gold);text-decoration:none;}

/* ── HEADER ── */
.hdr{background:var(--surface);border-bottom:1px solid var(--border);padding:20px 32px;display:flex;align-items:center;justify-content:space-between;}
.hdr-title{font-size:18px;font-weight:700;letter-spacing:.04em;color:var(--gold);}
.hdr-sub{font-size:11px;color:var(--text-dim);margin-top:2px;}
.hdr-badges{display:flex;gap:8px;flex-wrap:wrap;}
.badge{padding:4px 10px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.badge-gold{background:#2a1f00;border:1px solid var(--gold-dim);color:var(--gold);}
.badge-green{background:#0a2a12;border:1px solid #1a5c30;color:#4caf84;}
.badge-blue{background:#0a1a2a;border:1px solid #1a3a5c;color:#5ba0d0;}

/* ── TABS ── */
.tabs{background:var(--surface);border-bottom:1px solid var(--border);display:flex;overflow-x:auto;gap:0;}
.tabs::-webkit-scrollbar{height:3px;}
.tabs::-webkit-scrollbar-thumb{background:var(--gold-dim);}
.tab{padding:14px 22px;cursor:pointer;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;}
.tab:hover{color:var(--text-dim);}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}

/* ── CONTENT ── */
.content{display:none;padding:32px;}
.content.active{display:block;}

/* ── SECTION HEADERS ── */
.sec-title{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border);}

/* ── GRID UTILS ── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
.grid-4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;}
@media(max-width:900px){.grid-2,.grid-3,.grid-4{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.grid-2,.grid-3,.grid-4{grid-template-columns:1fr;}}

/* ── CARDS ── */
.card{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:20px;}
.card-gold{border-color:var(--gold-dim);background:#140f00;}
.card-green{border-color:#1a5c30;background:#050f08;}
.card-blue{border-color:#1a3a5c;background:#050a10;}
.card-red{border-color:#5c1a1a;background:#100505;}
.card-header{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;}
.card-value{font-size:28px;font-weight:700;color:var(--gold);line-height:1.1;}
.card-sub{font-size:11px;color:var(--text-dim);margin-top:4px;}

/* ── METRIC ROW ── */
.metric-row{display:flex;align-items:baseline;gap:8px;}
.metric-main{font-size:22px;font-weight:700;color:var(--gold);}
.metric-label{font-size:11px;color:var(--text-dim);}

/* ── TABLE ── */
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{background:var(--surface3);color:var(--text-dim);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);}
.tbl td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:top;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:var(--surface3);}
.tbl .num{text-align:right;font-variant-numeric:tabular-nums;}

/* ── PIPELINE ── */
.pipe-stages{display:flex;gap:0;flex-wrap:wrap;margin:12px 0;}
.stage{padding:8px 14px;font-size:11px;font-weight:700;border:1px solid var(--border);border-right:none;position:relative;background:var(--surface2);}
.stage:last-child{border-right:1px solid var(--border);}
.stage-num{font-size:9px;color:var(--text-muted);display:block;margin-bottom:2px;}
.stage-name{color:var(--text);}
.stage-sla{font-size:9px;color:var(--text-muted);margin-top:2px;}
.stage-owner{font-size:9px;color:var(--gold);margin-top:2px;}
.pipe-gold .stage{background:#140f00;border-color:var(--gold-dim);}
.pipe-green .stage{background:#050f08;border-color:#1a5c30;}

/* ── TAGS ── */
.tag{display:inline-block;padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:.06em;}
.tag-gold{background:#2a1f00;color:var(--gold);}
.tag-green{background:#0a2a12;color:#4caf84;}
.tag-blue{background:#0a1a2a;color:#5ba0d0;}
.tag-red{background:#2a0a0a;color:#e05050;}
.tag-amber{background:#2a1400;color:#e67e22;}
.tag-purple{background:#1a0a2a;color:#9b59b6;}

/* ── ARROW ── */
.arrow{color:var(--text-muted);padding:0 6px;}

/* ── SCRIPT BOX ── */
.script-box{background:var(--surface3);border-left:3px solid var(--gold);padding:16px;font-size:12px;line-height:1.7;border-radius:0 4px 4px 0;font-family:monospace;white-space:pre-wrap;color:var(--text);margin:8px 0;}

/* ── ALERT ── */
.alert-row{display:flex;align-items:flex-start;gap:12px;padding:12px;border-radius:5px;margin:8px 0;background:var(--surface2);border:1px solid var(--border);}
.alert-icon{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px;font-weight:700;}
.alert-igor .alert-icon{background:#0a1a2a;color:#5ba0d0;}
.alert-lorena .alert-icon{background:#2a1400;color:#e67e22;}
.alert-julia .alert-icon{background:#0a2a12;color:#4caf84;}
.alert-body{}
.alert-trigger{font-size:11px;font-weight:700;color:var(--text);}
.alert-detail{font-size:11px;color:var(--text-dim);}

/* ── PERSON COLUMN ── */
.person-hdr{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.person-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;}
.avatar-igor{background:#0a1a2a;color:#5ba0d0;border:2px solid #1a3a5c;}
.avatar-lorena{background:#2a1400;color:#e67e22;border:2px solid #5c2a00;}
.avatar-julia{background:#0a2a12;color:#4caf84;border:2px solid #1a5c30;}
.avatar-hiago{background:#1a0a2a;color:#9b59b6;border:2px solid #3a1a5a;}
.person-name{font-size:13px;font-weight:700;color:var(--text);}
.person-role{font-size:10px;color:var(--text-muted);}

/* ── TASK ITEM ── */
.task{display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--border);}
.task:last-child{border-bottom:none;}
.task-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:5px;}
.task-dot-urgent{background:var(--red);}
.task-text{font-size:12px;color:var(--text);}
.task-text small{color:var(--text-muted);font-size:10px;display:block;margin-top:2px;}

/* ── PHASE BLOCK ── */
.phase-block{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:16px;margin-bottom:12px;}
.phase-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:10px;}

/* ── AUTO ITEM ── */
.auto-item{display:grid;grid-template-columns:28px 1fr;gap:12px;padding:12px;border-radius:5px;margin:6px 0;background:var(--surface2);border:1px solid var(--border);}
.auto-num{color:var(--gold);font-size:13px;font-weight:700;font-variant-numeric:tabular-nums;}
.auto-title{font-size:12px;font-weight:700;color:var(--text);}
.auto-detail{font-size:11px;color:var(--text-dim);margin-top:3px;}
.auto-tech{margin-top:5px;}

/* ── FORECAST TABLE ── */
.fc-cell-hit{background:#0a2a12;color:#4caf84;}
.fc-cell-evt{background:#140f00;color:var(--gold);}
.fc-cell-mark{background:#100505;color:#e05050;}

/* ── DIVIDER ── */
.divider{border:none;border-top:1px solid var(--border);margin:24px 0;}

/* ── LIVE PANEL ── */
.live-badge{display:inline-flex;align-items:center;gap:5px;background:#0a2a0a;border:1px solid #1a5c30;color:#4caf84;padding:3px 9px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:.08em;vertical-align:middle;}
.progress-wrap{background:var(--surface3);border-radius:3px;height:5px;margin-top:8px;overflow:hidden;}
.progress-bar{height:5px;border-radius:3px;transition:width .6s ease;}
.bar-gold{background:var(--gold);}
.bar-green{background:#27ae60;}
.status-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:3px;font-size:10px;font-weight:700;width:100%;box-sizing:border-box;}
.pill-ativo{background:#0a2a12;color:#4caf84;border:1px solid #1a5c30;}
.pill-pendente{background:#2a1400;color:#e67e22;border:1px solid #5c3a00;}
.pill-problema{background:#2a0a0a;color:#e05050;border:1px solid #5c1a1a;}
.live-dot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0;}

/* ── UTIL ── */
.mt8{margin-top:8px;}.mt16{margin-top:16px;}.mt24{margin-top:24px;}.mt32{margin-top:32px;}
.mb8{margin-bottom:8px;}.mb16{margin-bottom:16px;}
.small{font-size:11px;color:var(--text-dim);}
.bold{font-weight:700;}
.gold{color:var(--gold);}
.green{color:#4caf84;}
.red{color:#e05050;}
.amber{color:#e67e22;}
.blue{color:#5ba0d0;}
.center{text-align:center;}
</style>
<script src="dados.js"></script>
</head>
