// ── PAINEL AO VIVO — lê dados.js ────────────────────────────
(function(){
  if(typeof ICBID === 'undefined') {
    document.getElementById('live-header').textContent = '⚠ dados.js não encontrado — abrir com servidor local ou GitHub Pages';
    return;
  }
  var d = ICBID;

  // Cabeçalho
  var wLabel = d.semana_atual === 0 ? 'Pré-campanha' : 'W' + d.semana_atual;
  document.getElementById('live-header').textContent = wLabel + ' · Atualizado em ' + (d.data_atualizacao || '—');

  // Leads
  document.getElementById('live-leads').textContent = d.leads_total || 0;
  var pLeads = Math.min(Math.round((d.leads_total||0) / 800 * 100), 100);
  document.getElementById('live-leads-sub').textContent = 'de 800 necessários · ' + pLeads + '%';
  document.getElementById('live-leads-bar').style.width = pLeads + '%';

  // Matrículas
  document.getElementById('live-mat').textContent = d.matriculas || 0;
  var pMat = Math.min(Math.round((d.matriculas||0) / 50 * 100), 100);
  document.getElementById('live-mat-sub').textContent = 'de 50 · ' + pMat + '% da meta';
  document.getElementById('live-mat-bar').style.width = pMat + '%';

  // CPL
  var cpl = d.cpl || 0;
  var cplEl = document.getElementById('live-cpl');
  cplEl.textContent = cpl > 0 ? 'R$ ' + cpl.toFixed(2) : '—';
  if(cpl > 15) cplEl.style.color = '#e05050';
  else if(cpl > 0 && cpl <= 10) cplEl.style.color = '#4caf84';

  // Investimento e receita
  var inv = d.investimento_total || 0;
  document.getElementById('live-inv').textContent = inv > 0 ? 'R$ ' + inv.toLocaleString('pt-BR') : '—';
  var rec = d.receita_acumulada || 0;
  document.getElementById('live-receita').textContent = 'Receita confirmada: ' + (rec > 0 ? 'R$ ' + rec.toLocaleString('pt-BR') : '—');

  // Comunidade
  document.getElementById('live-comunidade').textContent = d.membros_comunidade || 0;

  // P2
  var totalP2 = (d.inscritos_cl||0) + (d.inscritos_webinar||0);
  document.getElementById('live-p2').textContent = totalP2;
  document.getElementById('live-p2-sub').textContent = 'CL + Webinário · ' + (d.convertidos_p2||0) + ' converteram';

  // Risco
  var risco = d.alunos_em_risco || 0;
  document.getElementById('live-risco').textContent = risco;
  document.getElementById('live-hs').textContent = 'HS médio: ' + (d.health_score_medio > 0 ? d.health_score_medio + '/10' : '—');

  // Status das ferramentas
  var labels = {crm:'CRM EVO', gateway:'Gateway', ead:'Plataforma EAD', automacao:'Automação'};
  ['crm','gateway','ead','automacao'].forEach(function(k){
    var el = document.getElementById('pill-'+k);
    if(!el) return;
    var s = d[k+'_status'] || 'pendente';
    el.className = 'status-pill pill-' + s;
    el.innerHTML = '<span class="live-dot"></span>&nbsp;' + labels[k];
  });
})();
</script>
